{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": {
    "type": "object",
    "required": ["description", "tokens", "lighting_default"],
    "additionalProperties": false,
    "properties": {
      "description": { "type": "string" },
      "tokens": {
        "type": "string",
        "description": "Comma-separated SDXL tokens. No articles. Concise nouns/adjectives."
      },
      "lighting_default": { "type": "string" },
      "variations": {
        "type": "object",
        "additionalProperties": { "type": "string" }
      }
    }
  }
}
