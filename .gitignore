remotion-animation/outputs/*.tsx
!remotion-animation/outputs/.gitkeep

# IDE
.vscode/
.idea/
*.swp

# Tool caches
.pytest_cache/
.ruff_cache/

# Performance benchmark results — machine-specific, regenerated on every test run
image-generation/tests/benchmarks.json

media/

# Recording output (local, not committed) — ignore cast/gif/mp4 but track plan JSONs
recordings/**/*.cast
recordings/**/*.gif
recordings/**/*.mp4
recording-toolkit/recordings/

# Desktop recording checkpoints — generated during smoke tests
checkpoint-*.png
