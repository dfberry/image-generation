*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/
.env
*.egg-info/
dist/
build/

# Model weights — large files, download on demand via HuggingFace cache
*.bin
*.safetensors
*.ckpt
*.pt
*.pth
models/
weights/

# Generated images — don't commit outputs
image-generation/outputs/*.png
image-generation/outputs/*.jpg
image-generation/outputs/*.webp

# Test output images for visual inspection
image-generation/test-outputs/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Animation outputs
manim-animation/outputs/
manim-animation/media/
