{
  "name": "date-time-test",
  "description": "Quick test: print current date and time",
  "pre_record": {
    "commands": [
      "export PS1='demo $ '",
      "clear"
    ],
    "clear_screen": true
  },
  "record": {
    "commands": [
      {
        "type": "command",
        "value": "date",
        "wait_for_output": true,
        "pause_after": 2.0
      }
    ],
    "typing_speed": "medium",
    "default_pause": 1.0,
    "prompt": "demo $ ",
    "end_pause": 5
  },
  "output": {
    "subdir": "test",
    "convert": {
      "preset": "blog-landscape",
      "no_loop": true
    }
  }
}
