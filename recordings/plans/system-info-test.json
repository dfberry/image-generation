{
  "name": "system-info-test",
  "description": "Check system info with multiple commands (hostname, whoami, date, python3, node)",
  "pre_record": {
    "commands": [
      "command -v python3 >/dev/null 2>&1 || { echo 'Installing Python3...'; sudo apt-get update -qq && sudo apt-get install -y -qq python3; }",
      "command -v node >/dev/null 2>&1 || { echo 'Installing Node.js...'; sudo apt-get update -qq && sudo apt-get install -y -qq nodejs npm; }"
    ],
    "clear_screen": true
  },
  "record": {
    "commands": [
      {
        "type": "command",
        "value": "hostname",
        "wait_for_output": true,
        "pause_after": 1.5
      },
      {
        "type": "command",
        "value": "whoami",
        "wait_for_output": true,
        "pause_after": 1.5
      },
      {
        "type": "command",
        "value": "date",
        "wait_for_output": true,
        "pause_after": 1.5
      },
      {
        "type": "command",
        "value": "python3 --version",
        "wait_for_output": true,
        "pause_after": 1.5
      },
      {
        "type": "command",
        "value": "node --version",
        "wait_for_output": true,
        "pause_after": 1.5
      }
    ],
    "typing_speed": "medium",
    "default_pause": 1.0,
    "prompt": "$ ",
    "end_pause": 5
  },
  "output": {
    "subdir": "test",
    "convert": {
      "preset": "blog-landscape",
      "no_loop": true
    }
  }
}
