{
  "name": "copilot-cli-test",
  "description": "Demo the standalone GitHub Copilot CLI (npm install -g @github/copilot). Shows version check then a one-shot prompt via -p. The copilot binary is a plain npm global — no gh dependency. Requires GH_TOKEN or 'copilot login' to have been run beforehand.",
  "pre_record": {
    "commands": [
      "which copilot || npm install -g @github/copilot",
      "export PS1='demo $ '"
    ],
    "clear_screen": true
  },
  "record": {
    "commands": [
      {
        "type": "command",
        "value": "npm list -g @github/copilot",
        "wait_for_output": true,
        "pause_after": 1.5
      },
      {
        "type": "command",
        "value": "copilot --version",
        "wait_for_output": true,
        "pause_after": 2.0
      },
      {
        "type": "pause",
        "duration": 1.0
      },
      {
        "type": "command",
        "value": "copilot -p \"Tell me a programming joke\" --allow-all",
        "wait_for_output": true,
        "pause_after": 20.0
      },
      {
        "type": "pause",
        "duration": 2.0
      }
    ],
    "typing_speed": "slow",
    "default_pause": 1.5,
    "prompt": "demo $ ",
    "end_pause": 5
  },
  "output": {
    "subdir": "cli",
    "convert": {
      "preset": "blog-landscape",
      "format": "both",
      "no_loop": true
    }
  }
}
