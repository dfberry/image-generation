{
  "name": "node-quickstart-test",
  "description": "Node.js quickstart: create and run a simple script",
  "pre_record": {
    "commands": [
      "command -v node >/dev/null 2>&1 || { echo 'Installing Node.js...'; sudo apt-get update -qq && sudo apt-get install -y -qq nodejs npm; }",
      "rm -rf /tmp/node-demo && mkdir -p /tmp/node-demo && cd /tmp/node-demo && npm init -y --silent 2>/dev/null"
    ],
    "clear_screen": true
  },
  "record": {
    "commands": [
      {
        "type": "command",
        "value": "echo 'console.log(\"Hello, Azure!\")' > index.js",
        "wait_for_output": true,
        "pause_after": 1.5
      },
      {
        "type": "command",
        "value": "cat index.js",
        "wait_for_output": true,
        "pause_after": 2.0
      },
      {
        "type": "command",
        "value": "node index.js",
        "wait_for_output": true,
        "pause_after": 2.0
      },
      {
        "type": "command",
        "value": "cat package.json | head -5",
        "wait_for_output": true,
        "pause_after": 2.0
      }
    ],
    "typing_speed": "medium",
    "default_pause": 1.0,
    "prompt": "node-demo $ ",
    "end_pause": 5
  },
  "output": {
    "subdir": "test",
    "convert": {
      "preset": "blog-landscape",
      "no_loop": true,
      "format": "both"
    }
  }
}
