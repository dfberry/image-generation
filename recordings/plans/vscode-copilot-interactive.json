{
  "name": "vscode-copilot-interactive",
  "description": "VS Code + Copilot CLI interactive TUI session",
  "type": "desktop",
  "pre_record": {
    "commands": [
      "npm install -g @github/copilot"
    ]
  },
  "capture": {
    "mode": "full",
    "fps": 30
  },
  "steps": [
    { "action": "launch", "program": "code", "args": ["C:\\my-project"], "wait": 5 },
    { "action": "hotkey", "keys": ["ctrl", "`"], "wait": 1 },
    { "action": "type",   "text": "copilot", "interval": 0.05 },
    { "action": "press",  "key": "enter", "wait": 5 },
    { "action": "type",   "text": "write me a short programming joke", "interval": 0.04 },
    { "action": "press",  "key": "enter", "wait": 20 },
    { "action": "pause",  "wait": 3 },
    { "action": "hotkey", "keys": ["ctrl", "d"], "wait": 2 }
  ],
  "output": {
    "subdir": "desktop"
  }
}
